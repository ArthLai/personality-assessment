    "RM_POW":       { "label_zh": "權力動機", "label_en": "Power", "framework": "REISS", "pole_high": "喜歡影響他人方向", "pole_low": "不在乎影響力" },
    "RM_CUR":       { "label_zh": "好奇動機", "label_en": "Curiosity", "framework": "REISS", "pole_high": "持續探索新領域", "pole_low": "專注已知領域" },
