{
  "meta": {
    "name": "個人化人格與驅動測評",
    "version": "1.0.0",
    "author": "Arth × Claude",
    "totalQuestions": 110,
    "estimatedMinutes": "45-60",
    "language": "zh-Hant",
    "description": "整合 7 個心理學框架的人格、驅動、行為脈絡測評,含自動化解讀引擎"
  },

  "frameworks": [
    {
      "id": "BIG_FIVE",
      "name": "Big Five / Five Factor Model",
      "source": "Costa & McCrae (1992). NEO-PI-R Professional Manual.",
      "description": "學界共識最強的人格特質模型,五個維度描述人格的底層結構",
      "constructs": ["BF_O", "BF_C", "BF_E", "BF_A", "BF_N"]
    },
    {
      "id": "HEXACO",
      "name": "HEXACO Personality Inventory",
      "source": "Ashton & Lee (2007). Empirical, Theoretical, and Practical Advantages of the HEXACO Model.",
      "description": "Big Five 的延伸,新增誠實-謙遜維度,對人際動機有更強的解釋力",
      "constructs": ["HX_H"]
    },
    {
      "id": "SDT",
      "name": "Self-Determination Theory",
      "source": "Deci & Ryan (2000). The 'What' and 'Why' of Goal Pursuits.",
      "description": "三大基本心理需求:自主性、勝任感、連結。需求滿足程度決定內在動機強度",
      "constructs": ["SDT_AUT", "SDT_COM", "SDT_REL"]
    },
    {
      "id": "REISS",
      "name": "Reiss Motivation Profile (精選版)",
      "source": "Reiss (2004). Multifaceted Nature of Intrinsic Motivation.",
      "description": "16 種基本慾望的精選 8 項,形成個人的動機指紋",
      "constructs": ["RM_POW", "RM_CUR", "RM_IND", "RM_ORD", "RM_REC", "RM_HON", "RM_IDE", "RM_STA"]
    },
    {
      "id": "RF",
      "name": "Regulatory Focus Theory",
      "source": "Higgins (1997). Beyond Pleasure and Pain.",
      "description": "人做事的底層方向:促進焦點(追求正面結果)vs 預防焦點(避免負面結果)",
      "constructs": ["RF_PRO", "RF_PRE"]
    },
    {
      "id": "MINDSET_NFC",
      "name": "Dweck Mindset + Need for Cognition",
      "source": "Dweck (2006). Mindset; Cacioppo et al. (1984). Need for Cognition Scale.",
      "description": "思維模式(固定 vs 成長)與對深度思考的內在渴望",
      "constructs": ["MS_GRO", "MS_FIX", "NFC"]
    },
    {
      "id": "COG_STYLE",
      "name": "Cognitive Style Dimensions",
      "source": "Kirton (1976). Adaption-Innovation; Epstein (1996). CEST.",
      "description": "認知處理的偏好:由上而下 vs 由下而上、分析 vs 直覺、收斂 vs 發散",
      "constructs": ["COG_TOP", "COG_BOT", "COG_ANA", "COG_INT", "COG_DIV", "COG_INT_S"]
    },
    {
      "id": "CAPS",
      "name": "Mischel CAPS (Cognitive-Affective Processing System)",
      "source": "Mischel & Shoda (1995). A Cognitive-Affective System Theory of Personality.",
      "description": "情境化的 if-then 行為模式:同一個人在不同情境下展現不同行為的一致模式",
      "constructs": ["CAPS_SOC_HI", "CAPS_THREAT", "CAPS_BORE", "CAPS_ALONE", "CAPS_DEADLINE", "CAPS_HELP", "CAPS_CONFLICT", "CAPS_RULE", "CAPS_SHARE", "CAPS_PUSHBACK", "CAPS_LEISURE", "CAPS_NOVEL"]
    },
    {
      "id": "COPING",
      "name": "Coping Styles + Emotional Awareness",
      "source": "Lazarus & Folkman (1984). Stress, Appraisal, and Coping.",
      "description": "壓力下的應對策略:問題導向、情緒導向、迴避導向",
      "constructs": ["COP_PRO", "COP_EMO", "COP_AVO", "COP_EMO_NEG", "COP_SELF", "COP_SOLO", "EMO_AWARE"]
    },
    {
      "id": "SELF_ID",
      "name": "Self-Concept & Identity",
      "source": "Multiple: Clance & Imes (1978) Impostor Phenomenon; Crocker & Wolfe (2001) Contingencies of Self-Worth.",
      "description": "自我認知結構:後設認知、冒牌者感、價值基礎、身份整合",
      "constructs": ["META_AWARE", "IMPOSTER", "OTHER_REF", "SELF_DOING", "SELF_BEING", "REFLECT", "ID_CONFLICT"]
    }
  ],

  "constructs": {
    "BF_O":         { "label_zh": "經驗開放性", "label_en": "Openness to Experience", "framework": "BIG_FIVE", "pole_high": "好奇、想像力豐富、接受新事物", "pole_low": "務實、傳統、偏好常規" },
    "BF_C":         { "label_zh": "盡責性", "label_en": "Conscientiousness", "framework": "BIG_FIVE", "pole_high": "有組織、自律、目標導向", "pole_low": "靈活、隨性、衝動" },
    "BF_E":         { "label_zh": "外向性", "label_en": "Extraversion", "framework": "BIG_FIVE", "pole_high": "外向、精力充沛、健談", "pole_low": "內向、安靜、獨立" },
    "BF_A":         { "label_zh": "親和性", "label_en": "Agreeableness", "framework": "BIG_FIVE", "pole_high": "合作、信任、體貼", "pole_low": "競爭、懷疑、直言" },
